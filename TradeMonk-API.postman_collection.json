        {
            "name": "Payments",
            "item": [
                {
                    "name": "Create Payment Intent",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success) {",
                                    "    pm.collectionVariables.set(\"client_secret\", jsonData.clientSecret);",
                                    "    pm.collectionVariables.set(\"payment_intent_id\", jsonData.paymentIntentId);",
                                    "    console.log(\"Fee Breakdown:\");",
                                    "    console.log(\"  Items Total: €\" + jsonData.breakdown.itemsTotal);",
                                    "    console.log(\"  Service Fee: €\" + jsonData.breakdown.serviceFee);",
                                    "    console.log(\"  Buyer Total: €\" + jsonData.breakdown.buyerTotal);",
                                    "    console.log(\"  Platform Fee: €\" + jsonData.breakdown.platformFee);",
                                    "    console.log(\"  Seller Net: €\" + jsonData.breakdown.sellerNet);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"sellerId\": \"{{seller_id}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/payments/create-intent",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "payments",
                                "create-intent"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
